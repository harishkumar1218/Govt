# Django Secret Key (Must be kept secret in production!)
SECRET_KEY=django-insecure-upsc-aspire-secret-key-replace-in-prod

# Database Config
POSTGRES_DB=upsc_aspire
POSTGRES_USER=admin
POSTGRES_PASSWORD=secure_postgres_password_here

# Hosts and CORS
ALLOWED_HOSTS=yourdomain.com,127.0.0.1,localhost,backend
CORS_ALLOWED_ORIGINS=https://yourdomain.com,http://localhost

# Ollama Host
# In production, Ollama might run on the host server or another server
OLLAMA_BASE_URL=http://host.docker.internal:11434
